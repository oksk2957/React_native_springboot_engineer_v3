<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>객관식 랜덤학습</title>
    <style>
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 20px;
        }
        .container {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            max-width: 800px;
            margin: 0 auto;
        }
        h1 { color: #2d3748; margin-bottom: 1rem; }
        .subject-info { color: #4a5568; font-size: 0.9rem; margin-bottom: 1.5rem; }
        .problem-text { font-size: 1.2rem; margin-bottom: 1.5rem; line-height: 1.6; }
        .options { margin-bottom: 1.5rem; }
        .option-btn {
            display: block;
            width: 100%;
            padding: 12px;
            margin-bottom: 8px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            text-align: left;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            box-sizing: border-box;
        }
        .option-btn:hover { background-color: #edf2f7; border-color: #4a90e2; }
        .option-btn.selected { background-color: #bee3f8; border-color: #4a90e2; }
        .option-btn.correct { background-color: #c6f6d5; border-color: #38a169; }
        .option-btn.incorrect { background-color: #fed7d6; border-color: #e53e3e; }
        #result-area { 
            margin-top: 1.5rem; 
            padding: 15px; 
            border-radius: 8px; 
            display: none; 
        }
        .correct-result { background: #f0fff4; border: 1px solid #38a169; }
        .incorrect-result { background: #fff5f5; border: 1px solid #e53e3e; }
        .explanation { margin-top: 10px; padding: 10px; background: #edf2f7; border-radius: 5px; }
        .next-btn {
            background-color: #4a90e2;
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 1rem;
        }
        .next-btn:hover { background-color: #357abd; }
    </style>
</head>
<body>
    <div class="container">
        <h1>객관식 랜덤학습</h1>
        <div class="subject-info">
            전체 문제 수: {{totalProblems}} | 과목 수: {{subjects.size}}
        </div>

        {{#problems}}
        <div class="problem-item" style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #e2e8f0;" data-problem-id="{{id}}">
            <div class="problem-text">
                <strong>Q{{id}}. {{question}}</strong>
                <div style="font-size: 0.85rem; color: #718096; margin-top: 5px;">
                    과목: {{category}} | 난이도: {{difficulty}} | 유형: {{type}}
                </div>
            </div>
            
            <div class="options">
                {{#options}}
                <button class="option-btn" onclick="selectOption(this, '{{key}}', {{id}})">{{value}}</button>
                {{/options}}
            </div>

            <div id="result-{{id}}" class="result-area">
                <p id="result-text-{{id}}"></p>
                <div class="explanation">
                    <strong>해설:</strong>
                    <p id="explanation-text-{{id}}">{{explanation}}</p>
                </div>
                <button class="next-btn" onclick="nextProblem()">다음 문제</button>
            </div>
        </div>
        {{/problems}}

        {{^problems}}
        <div style="text-align: center; padding: 3rem; color: #718096;">
            <h2>표시할 문제가 없습니다</h2>
            <p>데이터베이스에 객관식 문제를 먼저 추가해주세요.</p>
            <button class="next-btn" onclick="location.reload()">다시 시도하기</button>
        </div>
        {{/problems}}
    </div>

    <script>
        const selectedOptions = {};

        function selectOption(btn, optionKey, problemId) {
            const parent = btn.parentElement;
            const buttons = parent.querySelectorAll('.option-btn');
            buttons.forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            selectedOptions[problemId] = optionKey;

            // 제출
            submitAnswer(problemId, optionKey);
        }

        async function submitAnswer(problemId, selectedOption) {
            const requestData = {
                problemId: problemId,
                submittedAnswer: selectedOption
            };

            try {
                const response = await fetch('/api/v1/answers/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestData)
                });

                if (!response.ok) throw new Error('네트워크 응답 에러');

                const result = await response.json();
                const resultArea = document.getElementById('result-' + problemId);
                const resultText = document.getElementById('result-text-' + problemId);
                
                resultArea.style.display = 'block';

                if (result.isCorrect) {
                    resultArea.className = 'result-area correct-result';
                    resultText.innerHTML = '<span style="color: #38a169; font-weight: bold;">정답입니다! 🎉</span>';
                    document.querySelector(`[data-problem-id="${problemId}"] .option-btn[onclick*="${selectedOption}"]`).classList.add('correct');
                } else {
                    resultArea.className = 'result-area incorrect-result';
                    resultText.innerHTML = '<span style="color: #e53e3e; font-weight: bold;">틀렸습니다. ✍️ (정답: ' + result.correctAnswer + ')</span>';
                    document.querySelector(`[data-problem-id="${problemId}"] .option-btn[onclick*="${selectedOption}"]`).classList.add('incorrect');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('오류가 발생했습니다.');
            }
        }

        function nextProblem() {
            location.reload();
        }
    </script>
</body>
</html>
